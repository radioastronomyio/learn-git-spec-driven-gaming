# ============================================================================
# .gitignore for learn-git-spec-driven-gaming
# ============================================================================

# ----------------------------------------------------------------------------
# SECRETS & CREDENTIALS
# ----------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
secrets/
credentials/
config.local.*
*.secrets

# ----------------------------------------------------------------------------
# WORKFLOW
# ----------------------------------------------------------------------------
*-pending.md
recycle/
internal-files/

# ----------------------------------------------------------------------------
# IDE & EDITOR
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ----------------------------------------------------------------------------
# NODE / PLAYWRIGHT
# ----------------------------------------------------------------------------
node_modules/
package-lock.json
yarn.lock
test-results/
playwright-report/
playwright/.cache/
blob-report/

# ----------------------------------------------------------------------------
# PYTHON (if any scripting)
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
venv/
.venv/

# ----------------------------------------------------------------------------
# BUILD & DOCUMENTATION
# ----------------------------------------------------------------------------
docs/_build/
site/
*.log
*.tmp
*.temp

# ----------------------------------------------------------------------------
# OS GENERATED
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----------------------------------------------------------------------------
# MISC
# ----------------------------------------------------------------------------
*.bak
*.backup
tmp/
temp/
